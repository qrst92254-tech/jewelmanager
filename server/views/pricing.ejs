<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <title>Pricing - JewelManager Pro</title>
  <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
</head>
<body>
  <h1>Pricing</h1>
  <% if (message) { %>
    <div style="color:red"><%= message %></div>
  <% } %>

  <div style="display:flex;gap:20px">
    <div>
      <h2>7-Day Free Trial</h2>
      <p>₹0 — Full access for 7 days, No credit card required</p>
      <a href="/signup"><button>Start Free Trial</button></a>
    </div>

    <div style="border:2px solid #000;padding:10px">
      <h2>Monthly (Most Popular)</h2>
      <p>₹79 / month — Full access, Cancel anytime, Priority support</p>
      <button id="subscribe-monthly">Subscribe ₹79/mo</button>
    </div>

    <div>
      <h2>Lifetime Access</h2>
      <p>₹4,879 one-time — Pay once, own forever, All future updates included</p>
      <button id="buy-lifetime">Buy Lifetime ₹4,879</button>
    </div>
  </div>

  <script>
    async function postJSON(url, data) {
      const res = await fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });
      return res.json();
    }

    document.getElementById('subscribe-monthly').addEventListener('click', async () => {
      const res = await postJSON('/api/subscription/create-subscription', {});
      if (res.error) return alert(res.error);

      const options = {
        key: res.keyId,
        name: res.name,
        subscription_id: res.subscriptionId,
        handler: async function (response){
          await postJSON('/api/subscription/activate', {
            plan: 'monthly',
            razorpay_payment_id: response.razorpay_payment_id,
            razorpay_subscription_id: response.razorpay_subscription_id,
            razorpay_signature: response.razorpay_signature,
          });
          window.location = '/dashboard';
        },
      };
      const rzp = new Razorpay(options);
      rzp.open();
    });

    document.getElementById('buy-lifetime').addEventListener('click', async () => {
      const res = await postJSON('/api/subscription/create-order', {});
      if (res.error) return alert(res.error);
      const options = {
        key: res.keyId,
        name: res.name,
        order_id: res.orderId,
        handler: async function (response) {
          await postJSON('/api/subscription/activate', {
            plan: 'lifetime',
            razorpay_payment_id: response.razorpay_payment_id,
            razorpay_order_id: response.razorpay_order_id,
            razorpay_signature: response.razorpay_signature,
          });
          window.location = '/dashboard';
        }
      };
      const rzp = new Razorpay(options);
      rzp.open();
    });
  </script>
</body>
</html>